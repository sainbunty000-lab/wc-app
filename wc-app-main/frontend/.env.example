# -------------------------------------------------------
# Frontend environment variables — copy to .env for local dev
# All EXPO_PUBLIC_* vars are bundled into the client at build time.
# -------------------------------------------------------

# Base URL of the deployed Railway backend (no trailing slash)
# Local dev default is http://localhost:8001 (set in src/api/index.ts fallback)
EXPO_PUBLIC_BACKEND_URL=https://your-app.up.railway.app
