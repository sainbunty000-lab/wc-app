# -------------------------------------------------------
# Backend environment variables — copy to .env for local dev
# Railway: set these in the Railway dashboard (never commit .env)
# -------------------------------------------------------

# MongoDB connection string
# Railway MongoDB plugin sets this automatically; override only if using Atlas
MONGO_URL=mongodb://localhost:27017

# Database name
DB_NAME=financial_analytics

# Gemini Vision API key (optional — enables AI document parsing)
EMERGENT_LLM_KEY=

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated list for production)
# Example: CORS_ORIGINS=["https://your-app.up.railway.app"]
# Default in server.py is ["*"] — restrict before going live
CORS_ORIGINS=["*"]
