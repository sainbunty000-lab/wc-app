{
  "build": {
    "builder": "dockerfile",
    "buildCommand": "cd backend && docker build -t wc-app:latest .",
    "startCommand": "cd backend && uvicorn server:app --host 0.0.0.0 --port $PORT --workers 4"
  },
  "deploy": {
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
