{
  "expo": {
    "name": "Capital Analytics",
    "slug": "capital-analytics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "capital-analytics",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sainbunty000.capitalanalytics",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Select financial documents for analysis",
        "NSDocumentsFolderUsageDescription": "Access documents for financial analysis"
      }
    },

    "android": {
      "package": "com.sainbunty000.capitalanalytics",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },

    "extra": {
      "eas": {
        "projectId": "1d3fd9b2-d667-4a7a-a475-68143afee191"
      }
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      "expo-document-picker"
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}
